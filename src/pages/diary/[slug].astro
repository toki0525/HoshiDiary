---
//css読み込ませる
import "../../style/stylesheet.css";
import { getSheetData } from "../../lib/getSheetData.js";

export async function getStaticPaths(){
    const data = await getSheetData();

    return data.map(entry => ({
        params: {
            slug: entry.slug
        }
    }));
}

const { slug } = Astro.params;
const data = await getSheetData();
const entry = data.find(e => e.slug === slug);

---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/icon.svg" />
		<link rel="icon" href="/icon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>星より、</title>
	</head>
	<body>
        <div class = "diary-header">
		    <h1>{entry?.title || slug}</h1>
            <p class = "diary_time">{entry?.date}</p>
        </div>

            <!-- 日記本文 -->
            <div class="content">

                <div class="diary-text">
                    <p class="diary-body">{entry?.body}</p>
                    <div class="diary-emoji">
                        <span class="emoji">{entry?.emoji}</p>
                    </div>
                </div>

                <div class="button-wrap">
                    <a href="/" class="back-button">← ホームへ</a>
                </div>
                
            </div>
        </main>
	</body>
</html>
